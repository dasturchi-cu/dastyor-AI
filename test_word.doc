
<html xmlns:o='urn:schemas-microsoft-com:office:office' xmlns:w='urn:schemas-microsoft-com:office:word' xmlns='http://www.w3.org/TR/REC-html40'>
<head>
<meta charset='utf-8'>
<style>
body { font-family: Arial; }
.box { width: 100%; border: 1px solid black; padding: 10px; }
.header { background: blue; color: white; display: flex; } /* Word won't understand flex, but lets test */
</style>
</head>
<body>
<div class='box'><div class='header'>Hello Word!</div></div>
</body>
</html>
